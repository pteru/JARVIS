flowchart TB
    %% ===== EXTERNAL SOURCES =====
    subgraph SOURCES["Fontes Externas (Live)"]
        CU["ClickUp<br/>Tarefas, Status,<br/>Sprints"]:::camBlue
        GH["GitHub<br/>PRs, Commits,<br/>Code Reviews"]:::camBlue
        GD["Google Drive<br/>SoR: CAD, Specs, Quotes,<br/>Datasheets, Standards"]:::camBlue
        GM["Gmail<br/>Emails de Projeto"]:::camBlue
        GC["Google Chat<br/>Conversas nos<br/>Espaços de Projeto"]:::camBlue
    end

    %% ===== INDEX LAYER =====
    subgraph INDEX["Indexação Periódica"]
        IDX_DRIVE["gdrive-index.sh<br/>Semanal<br/>→ drive-index.json"]:::default
        IDX_EMAIL["email-index.sh<br/>Semanal<br/>→ emails/index.json"]:::default
        IDX_CHAT["jarvis-chat distill<br/>Horário<br/>→ facts/*.jsonl"]:::default
    end

    %% ===== PMO REPO (TEAM SHARED) =====
    subgraph PMO["PMO Repository — Compartilhado pela equipe (git)"]
        direction TB
        subgraph PROJ["projects/{code}/ — por projeto"]
            README["README.md<br/>Orientação do projeto<br/>Links p/ reports"]:::success
            subgraph INDEXES["Índices (gerados)"]
                DI["drive-index.json"]:::weld
                EI["emails/index.json"]:::weld
            end
            subgraph REPORTS["reports/md/ — Documentação viva"]
                STD_OV["overview.md ★"]:::success
                STD_ST["status.md ★"]:::success
                STD_DEC["decisions.md ★"]:::success
                CUSTOM["[relatórios<br/>específicos]"]:::default
            end
            CLAUDE_CTX[".claude/context.md<br/>Resumo p/ IA<br/>(gerado dos reports)"]:::camYellow
            CACHE["cache/<br/>(gitignored)"]:::weld
        end
        META["config/project-codes.json<br/>Registro central"]:::weld
    end

    %% ===== CHAT MEMORY =====
    subgraph CHATMEM["Memória de Chat"]
        TX["transcripts/"]:::weld
        FS["facts/*.jsonl"]:::weld
    end

    %% ===== KB GENERATION =====
    subgraph KBGEN["JARVIS KB Generator (Periódico)"]
        GEN["claude --print<br/>1. Lê índices + facts<br/>2. Consulta Drive on-demand<br/>3. Regenera reports ★<br/>4. Regenera context.md<br/>5. Commit + upload Drive"]:::camYellow
    end

    %% ===== CENTRAL KB =====
    CKB["KB Central<br/>knowledge-base/<br/>Cross-projeto, curada<br/>128 páginas PT-BR"]:::success

    %% ===== DRIVE SoR =====
    subgraph DRIVE_SOR["Google Drive — SoR"]
        D_FOLDERS["01 a 07<br/>Desenhos, Specs,<br/>Comunicação, Relatórios,<br/>Administrativo, Referência"]:::camBlue
    end

    %% ===== CONSUMERS =====
    subgraph CONSUMERS["Consumidores"]
        LOCAL["Pedro<br/>/pmo → context.md<br/>/gdrive → cache/"]:::camBlue
        DEV["Engenheiro<br/>git pull → README<br/>→ reports/md/"]:::camBlue
        JBOT["jarvis-chat<br/>Bot nos espaços"]:::camYellow
        KBOT["kb-chat<br/>DM do Pedro"]:::camYellow
    end

    %% ===== FLOW: Sources → Indexing =====
    GD --> IDX_DRIVE
    GM --> IDX_EMAIL
    GC -->|"poll 1 min"| TX
    TX -->|"distill"| IDX_CHAT

    %% ===== FLOW: Indexing → PMO =====
    IDX_DRIVE --> DI
    IDX_EMAIL --> EI
    IDX_CHAT --> FS

    %% ===== FLOW: Drive ↔ PMO =====
    D_FOLDERS <-->|"download on-demand<br/>upload reports"| CACHE
    REPORTS -->|"upload MD + PDF"| D_FOLDERS

    %% ===== FLOW: Sources → KB Generator =====
    DI --> GEN
    EI --> GEN
    FS --> GEN
    CU -.->|"tarefas ativas"| GEN
    CACHE -.->|"docs Drive<br/>on-demand"| GEN

    %% ===== FLOW: Generation → outputs =====
    GEN -->|"regenera ★"| REPORTS
    GEN -->|"gera resumo"| CLAUDE_CTX

    %% ===== FLOW: Reports → Central KB =====
    REPORTS -.->|"cross-projeto<br/>alimenta curadoria"| CKB

    %% ===== FLOW: → Consumers =====
    CLAUDE_CTX --> LOCAL
    README --> DEV
    REPORTS --> DEV
    REPORTS --> JBOT
    CKB --> KBOT
    CKB --> JBOT

    %% ===== FLOW: Lane 1 =====
    GH -.->|"Lane 1: PR reviews"| JBOT

