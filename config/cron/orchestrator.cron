# 30 23 * * * ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/health/health.sh vk 03002 trends >> /home/teruel/JARVIS/logs/cron-health-vk-03002.log 2>&1
