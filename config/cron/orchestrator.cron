# 0 6 1 * * PATH=/home/teruel/.local/bin:/usr/bin:/bin ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/health/health.sh vk 03002 monthly-consolidate >> /home/teruel/JARVIS/logs/cron-health-vk-03002.log 2>&1
