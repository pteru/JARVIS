# Claude Orchestrator — Automated Schedules
# SNAPSHOT of the live crontab (regenerated 2026-07-04 by the structure-audit B5 task).
# Restore on this machine:   crontab config/cron/orchestrator.cron
# Provision another host:    sed "s|/home/teruel|$HOME|g" then review secrets in ~/.secrets/.
# Drift is checked weekly by scripts/system-health-check.sh (CHECK_13).

# Claude Orchestrator - Automated Schedules

# Daily: Update GitHub access matrix at 6:00 AM
0 6 * * * ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/orchestrator.sh update-access >> /home/teruel/JARVIS/logs/cron-access.log 2>&1

# Daily: Fetch all remotes at 7:30 AM (before backlog processing)
30 7 * * * ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/orchestrator.sh fetch-remotes >> /home/teruel/JARVIS/logs/cron-fetch.log 2>&1

# Daily: JARVIS morning briefing at 7:45 AM
45 7 * * * ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/morning-report.sh >> /home/teruel/JARVIS/logs/cron-morning.log 2>&1

# Weekly: Suggest weekly goals on Monday at 8:00 AM
0 8 * * 1 ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/orchestrator.sh suggest-goals >> /home/teruel/JARVIS/logs/cron-goals.log 2>&1

# Daily: Process backlogs at 9:00 AM
0 9 * * * ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/orchestrator.sh refresh-backlog-cache >> /home/teruel/JARVIS/logs/cron-daily.log 2>&1

# Every 30min: PR inbox — fetch open PRs then review unreviewed ones (parallel, max 3)
# */30 * * * * ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/fetch-open-prs.sh >> /home/teruel/JARVIS/logs/cron-pr-inbox.log 2>&1 && ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/review-pr.sh --all --parallel 3 >> /home/teruel/JARVIS/logs/cron-pr-inbox.log 2>&1

# Daily: Archive merged/closed PR reviews at 11:00 PM
# 0 23 * * * ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/helpers/archive-merged-reviews.sh >> /home/teruel/JARVIS/logs/cron-pr-inbox.log 2>&1

# Daily: Generate daily report at 5:00 PM
0 17 * * * ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/orchestrator.sh daily-report >> /home/teruel/JARVIS/logs/cron-report.log 2>&1

# Weekly: Generate weekly report on Friday at 4:00 PM
0 16 * * 5 ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/orchestrator.sh weekly-report >> /home/teruel/JARVIS/logs/cron-weekly.log 2>&1

# Hourly: Fetch, classify, and parse new project emails
# DISABLED 2026-06-15 (script removed, no replacement wired): 0 * * * * ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/email-ingest.sh >> /home/teruel/JARVIS/logs/cron-email.log 2>&1

# VK health check — every 15 min (collect + AI analyze + alert)
*/15 * * * * VK_SSH_PASSWORD="$(cat ~/.secrets/vk-ssh-password)" VK_RABBIT_PASSWORD="$(cat ~/.secrets/vk-rabbit-password)" ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/vk-health/run.sh 03002 >> /home/teruel/JARVIS/logs/cron-vk-health.log 2>&1

# VK daily trend aggregation — 11:30 PM
30 23 * * * ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/vk-health/trends.sh 03002 >> /home/teruel/JARVIS/logs/cron-vk-health.log 2>&1

# JARVIS weekly system health check — Sunday 21:00
0 21 * * 0 ORCHESTRATOR_HOME=/home/teruel/JARVIS bash /home/teruel/JARVIS/scripts/system-health-check.sh --quiet >> /home/teruel/JARVIS/logs/cron-system-health.log 2>&1

# JARVIS weekly self-improvement analysis — Sunday 22:00
0 22 * * 0 ORCHESTRATOR_HOME=/home/teruel/JARVIS bash /home/teruel/JARVIS/scripts/weekly-self-improvement.sh >> /home/teruel/JARVIS/logs/cron-self-improvement.log 2>&1

# JARVIS VK health report cleanup — daily 04:00
0 4 * * * ORCHESTRATOR_HOME=/home/teruel/JARVIS bash /home/teruel/JARVIS/scripts/vk-health/cleanup-reports.sh >> /home/teruel/JARVIS/logs/cron-vk-cleanup.log 2>&1

# Monthly VK health consolidation — 1st of month at 06:00
0 6 1 * * ORCHESTRATOR_HOME=/home/teruel/JARVIS /home/teruel/JARVIS/scripts/vk-health/monthly-consolidate.sh 03002 >> /home/teruel/JARVIS/logs/cron-vk-health.log 2>&1

